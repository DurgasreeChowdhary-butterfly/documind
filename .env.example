# ─── LLM ───────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ─── VECTOR STORE ───────────────────────────────────
# Option A: Pinecone (production — recommended)
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=documind

# Option B: FAISS (local fallback — no key needed)
# Leave PINECONE_API_KEY empty to auto-use FAISS

# ─── APP CONFIG ─────────────────────────────────────
VECTOR_STORE=pinecone        # "pinecone" or "faiss"
GEMINI_MODEL=gemini-2.5-flash
CHUNK_SIZE=500
CHUNK_OVERLAP=100
TOP_K_RESULTS=4
MAX_FILE_SIZE_MB=50
